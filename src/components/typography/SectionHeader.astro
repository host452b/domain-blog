---
interface Props {
  text: string;
  tag?: 'h1' | 'h2' | 'h3';
}

const { text, tag = 'h2' } = Astro.props;
const Tag = tag;
---
<Tag class="section-header">
  {text}
</Tag>

<style>
  .section-header {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.5em;
    position: relative;
  }

  .section-header:hover {
    letter-spacing: 0.005em;
    transition: letter-spacing 0.3s ease;
  }
</style>
