---
interface Props {
  text: string;
}

const { text } = Astro.props;
---
<div class="tldr">
  {text}
</div>

<style>
  .tldr {
    background: rgba(0, 0, 0, 0.02);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
    border-radius: 2px;
  }

  [data-theme='dark'] .tldr {
    background: rgba(255, 255, 255, 0.03);
  }
</style>
