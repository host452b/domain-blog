---
/**
 * Giscus 评论组件
 * 基于 GitHub Discussions，免费、无广告、支持暗色模式
 *
 * 配置步骤:
 * 1. 在 GitHub 仓库启用 Discussions
 * 2. 安装 Giscus App: https://github.com/apps/giscus
 * 3. 到 https://giscus.app/ 配置并获取参数
 * 4. 替换下面的 data-repo 等参数
 */
---
<div class="comments" id="comments">
  <h3 class="comments-title">评论 / Comments</h3>
  <script
    src="https://giscus.app/client.js"
    data-repo="host452b/domain-blog"
    data-repo-id="R_kgDOR_5YvA"
    data-category="Announcements"
    data-category-id="DIC_kwDOR_5YvM4C65CV"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang="zh-CN"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</div>

<style>
  .comments {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .comments-title {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      Helvetica, Arial, sans-serif, 'LXGWNeoXiHei';
  }
</style>

<script>
  // 跟随暗色模式切换 Giscus 主题
  const observer = new MutationObserver(() => {
    const theme = document.documentElement.dataset.theme;
    const iframe = document.querySelector<HTMLIFrameElement>('.giscus-frame');
    if (iframe) {
      iframe.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: theme === 'dark' ? 'dark' : 'light' } } },
        'https://giscus.app'
      );
    }
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
